# Copy to .env and fill with your Razorpay TEST keys (dashboard.razorpay.com > Settings > API Keys).
# Leave blank to run in MOCK mode: the full cart and checkout flow still works end to end,
# the payment step is simulated instead of calling Razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PORT=5174
